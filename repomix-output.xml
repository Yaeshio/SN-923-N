beforeEach(() => {
  mockReset(prismaMock)
  // リセット後、$transactionの実装を再度設定
  prismaMock.$transaction.mockImplementation((cb: any) => {
    return Promise.resolve(typeof cb === 'function' ? cb(prismaMock) : cb)
  })
})
